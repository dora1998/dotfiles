{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(ln:*)",
      "Bash(unlink:*)",
      "Bash(go version)",
      "Bash(go doc:*)",
      "Bash(go test:*)",
      "Bash(go list:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy)",
      "Bash(git:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(osascript:*)",
      "Bash(gcloud logging read:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl config get-contexts)",
      "Bash(kubectl config use-context:*)",
      "Bash(kubectl config current-context)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:opentelemetry.io)",
      "Bash(gcloud version:*)",
      "Bash(bq query *)"
    ],
    "deny": [
      "Bash(git config:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(brew install:*)",
      "Bash(npm install -g:*)",
      "Bash(mise:*)",
      "Bash(gh auth:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret remove:*)",
      "mcp__linear-server__delete_comment",
      "mcp__linear-server__delete_status_update",
      "mcp__linear-server__delete_attachment",
      "Bash(chmod 777*)",
      "Bash(sudo rm*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.aws/credentials)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "ccusage statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": false,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }{{ onepasswordDocument "ddoxcazfyvyg6gvktonxofq36u" }}
  },
  "language": "japanese",
  "sandbox": {
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org"
      ],
      "allowUnixSockets": [
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ]
    },
    "enableWeakerNetworkIsolation": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754399891635
  }
}
